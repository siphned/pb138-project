PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pb138"
SLOW_MODE=true

# Clerk — create a project at https://clerk.com and copy from API Keys tab
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Sentry — create a project at https://sentry.io and copy the DSN
SENTRY_DSN=https://your_key@sentry.io/your_project_id

# OpenTelemetry — ClickStack (HyperDX) local instance (docker-compose)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=pb138-server
# ClickStack ingestion API key — copy from http://localhost:8080 → Team Settings → API Keys
CLICKSTACK_API_KEY=your_clickstack_api_key_here
