    "/courses/": {
      "get": {
        "tags": [
          "Courses"
        ],
        "description": "Returns all courses. Supports optional filtering via query parameters.",
        "parameters": [
          {
            "name": "semester",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "fall",
                "spring"
              ]
            }
          },
          {
            "name": "minCredits",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            }
          },
          {
            "name": "maxCredits",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            }
          },
          {
            "name": "instructorId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CourseList"
                }
              }
            }
          }
        },
        "operationId": "getCourses"
      },
      "post": {
        "tags": [
          "Courses"
        ],
        "description": "Creates a new course. The request body is validated by Zod.",
