# Copy to `.env` (gitignored) before running `docker compose up`.
# Compose interpolates these into the server env and the web build args.

# --- Clerk (required) ---
# Server-side secret + JWT verification key (from Clerk dashboard).
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----"

# Frontend publishable key — baked into the web bundle at build time.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# --- Public URLs (set for remote deploy; omit for localhost) ---
# Browser hits the API cross-origin, so this is BAKED into the web bundle at
# build time. Must be the public address of the server.
# VITE_API_URL=http://203.0.113.10:3000
# Server CORS origin + Clerk authorizedParties. Must equal the URL in the browser.
# FRONTEND_URL=http://203.0.113.10

# --- Optional ---
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_...
# RESEND_API_KEY=re_...
# TEST_USER_CLERK_ID=user_...   # used by the demo seed
