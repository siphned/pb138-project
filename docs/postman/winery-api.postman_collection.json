  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{clerk_jwt_token}}"}]},
            "method": "GET",
            "url": {"raw": "{{base_url}}/users/me", "host": ["{{base_url}}"], "path": ["users", "me"]}
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{clerk_jwt_token}}"}]},
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"firstName\": \"John\", \"lastName\": \"Doe\"}"},
            "url": {"raw": "{{base_url}}/users/me", "host": ["{{base_url}}"], "path": ["users", "me"]}
          }
        },
        {
          "name": "Get Addresses",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{clerk_jwt_token}}"}]},
            "method": "GET",
            "url": {"raw": "{{base_url}}/users/me/addresses", "host": ["{{base_url}}"], "path": ["users", "me", "addresses"]}
          }
        },
        {
          "name": "Set Shipping Address",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{clerk_jwt_token}}"}]},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"type\": \"shipping\", \"street\": \"123 Main\", \"houseNumber\": \"42\", \"city\": \"Prague\", \"postalCode\": \"11000\", \"country\": \"Czech Republic\"}"},
            "url": {"raw": "{{base_url}}/users/me/addresses", "host": ["{{base_url}}"], "path": ["users", "me", "addresses"]}
          }
        }
      ]
    },
