        {
          "name": "Get Current User",
          "request": {
            "auth": {
              "bearer": [{ "key": "token", "value": "{{clerk_jwt_token}}" }],
              "type": "bearer"
            },
            "method": "GET",
            "url": {
              "host": ["{{base_url}}"],
              "path": ["users", "me"],
              "raw": "{{base_url}}/users/me"
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "auth": {
              "bearer": [{ "key": "token", "value": "{{clerk_jwt_token}}" }],
              "type": "bearer"
            },
            "body": { "mode": "raw", "raw": "{\"firstName\": \"John\", \"lastName\": \"Doe\"}" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "method": "PUT",
            "url": {
              "host": ["{{base_url}}"],
              "path": ["users", "me"],
              "raw": "{{base_url}}/users/me"
            }
          }
        },
        {
          "name": "Get Addresses",
          "request": {
            "auth": {
              "bearer": [{ "key": "token", "value": "{{clerk_jwt_token}}" }],
              "type": "bearer"
            },
            "method": "GET",
            "url": {
              "host": ["{{base_url}}"],
              "path": ["users", "me", "addresses"],
              "raw": "{{base_url}}/users/me/addresses"
            }
