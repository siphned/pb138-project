            },
            "body": {
              "mode": "raw",
              "raw": "{\"type\": \"shipping\", \"street\": \"123 Main\", \"houseNumber\": \"42\", \"city\": \"Prague\", \"postalCode\": \"11000\", \"country\": \"Czech Republic\"}"
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "method": "POST",
            "url": {
              "host": ["{{base_url}}"],
              "path": ["users", "me", "addresses"],
              "raw": "{{base_url}}/users/me/addresses"
            }
          }
