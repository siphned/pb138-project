            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"guestName\": \"John Doe\", \"guestEmail\": \"john@example.com\", \"paymentMethod\": \"card\", \"deliveryType\": \"shipping\", \"shippingAddress\": {\"street\": \"456 Oak\", \"houseNumber\": \"10\", \"city\": \"Brno\", \"postalCode\": \"60200\", \"country\": \"Czech Republic\"}}"},
