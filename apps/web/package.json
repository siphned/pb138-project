  "name": "web",
  "private": true,
  "scripts": {
    "build": "tsc -b && vite build",
    "check-types": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "dev": "vite",
    "generate": "kubb",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "concurrently --kill-others-on-exit 'bun run --cwd ../.. dev:server' 'bun run --cwd ../.. dev:web' 'sleep 10 && concurrently \"bun run test:e2e:shard:1\" \"bun run test:e2e:shard:2\" \"bun run test:e2e:shard:3\"'",
    "test:e2e:sequential": "CI=true playwright test",
    "test:e2e:shard:1": "SHARD=1/3 CI=true playwright test",
    "test:e2e:shard:2": "SHARD=2/3 CI=true playwright test",
    "test:e2e:shard:3": "SHARD=3/3 CI=true playwright test"
  },
  "type": "module",
  "version": "0.0.0"
}
