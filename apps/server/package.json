{
  "dependencies": {
    "@clerk/backend": "^3.2.12",
    "@elysiajs/cors": "^1.1.0",
    "@elysiajs/openapi": "^1.4.14",
    "@repo/shared": "workspace:*",
    "@stablelib/base64": "^1.0.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "resend": "^6.12.2",
    "svix": "^1.93.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "vitest": "^4.1.5",
    "@faker-js/faker": "^10.4.0",
    "pino-pretty": "^13.1.3"
  },
  "module": "index.ts",
  "name": "server",
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "private": true,
  "scripts": {
    "build": "tsc",
    "check": "biome check --write .",
    "check-types": "tsc --noEmit",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/db/seed.ts",
    "db:seed:demo": "bun run src/db/seed.demo.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "bun run src/index.ts",
    "format": "biome format --write .",
    "generate": "bun run scripts/export-spec.ts",
    "generate:spec": "bun run scripts/export-spec.ts",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "echo 'Run E2E tests from web package'"
  },
  "type": "module"
}
