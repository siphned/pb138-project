{
  "dependencies": {
    "@clerk/backend": "^3.2.12",
    "@elysiajs/cors": "^1.1.0",
    "@elysiajs/openapi": "^1.4.14",
    "@faker-js/faker": "^10.4.0",
    "@repo/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.28",
    "pg": "^8.20.0",
    "resend": "^6.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "vitest": "^2.1.8"
  },
  "module": "index.ts",
  "name": "server",
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "bun run src/index.ts",
    "format": "biome format --write .",
    "generate": "bun run scripts/export-spec.ts",
    "generate:spec": "bun run scripts/export-spec.ts",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:e2e": "echo 'Run E2E tests from web package'"
  },
  "type": "module"
}
